{
  "name": "@tonconnect/kit",
  "version": "0.1.0",
  "description": "",
  "private": true,
  "scripts": {
    "appkit": "pnpm --filter @ton/appkit",
    "appkit-react": "pnpm --filter @ton/appkit-react",
    "walletkit": "pnpm --filter @ton/walletkit",
    "examples": "pnpm --filter @ton/walletkit-examples",
    "docs:update": "tsx scripts/update-docs.ts",
    "demo-wallet": "pnpm --filter demo-wallet",
    "demo-wallet-native": "pnpm --filter demo-wallet-native",
    "appkit-minter": "pnpm --filter appkit-minter",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint-files": "eslint --max-warnings 0",
    "lint-files:fix": "eslint --max-warnings 0 --fix",
    "lint": "pnpm lint-files .",
    "lint:fix": "pnpm lint-files:fix .",
    "quality": "turbo quality",
    "quality:bridge": "turbo quality:bridge",
    "typecheck": "turbo typecheck",
    "e2e": "turbo e2e",
    "clean": "turbo run clean && rimraf --glob node_modules .turbo 'packages/*/node_modules' 'apps/*/node_modules' 'demo/*/node_modules'",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "generate-openapi-spec": "turbo generate-openapi-spec",
    "generate-openapi-spec-fixtures": "turbo generate-openapi-spec-fixtures"
  },
  "prettier": "@ton/toolchain/prettier",
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@ton/toolchain": "github:the-ton-tech/toolchain#v1.7.0",
    "eslint": "catalog:",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-license-header": "^0.9.0",
    "globals": "^17.5.0",
    "rimraf": "catalog:",
    "turbo": "2.9.14"
  },
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215"
