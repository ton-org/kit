{
  "name": "@ton/mcp",
  "version": "0.1.15-alpha.16",
  "description": "TON MCP Server - Model Context Protocol server for TON blockchain wallet operations",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": "./bin/mcp.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./serverless": {
      "import": {
        "types": "./dist/serverless.d.ts",
        "default": "./dist/serverless.js"
      },
      "require": {
        "types": "./dist/serverless.d.ts",
        "default": "./dist/serverless.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "dist",
    "skills",
    "llms.txt",
    "USAGE_EXAMPLES.md",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm build:clean && rolldown -c && pnpm build:types",
    "build:clean": "rimraf dist",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "build:chmod": "chmod +x dist/cli.js",
    "dev": "rolldown --watch -c",
    "dev:cli": "node --import tsx/esm src/cli.ts",
    "dev:cli:http": "node --import tsx/esm src/cli.ts --http",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --max-warnings 0 --fix",
    "test": "vitest run",
    "clean": "git clean -xdf dist node_modules .turbo",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ton",
    "mcp",
    "wallet",
    "model-context-protocol",
    "blockchain"
  ],
  "author": "TON Tech",
  "repository": {
    "type": "git",
    "url": "https://github.com/ton-connect/kit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@ston-fi/omniston-sdk": "^0.7.9",
    "@ton/core": "catalog:",
    "@ton/crypto": "catalog:",
    "@ton/walletkit": "workspace:*",
    "https-proxy-agent": "^9.0.0",
    "undici": "8.0.2",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.7",
    "rimraf": "catalog:",
    "rolldown": "1.0.2",
    "typescript": "catalog:",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
