{
    "compilerOptions": {
        "target": "ES2023",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "outDir": "dist",
        "rootDir": "src",
        "types": ["node"],
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "esModuleInterop": true,
        "verbatimModuleSyntax": true,
        "moduleDetection": "force",
        "erasableSyntaxOnly": true
    },
    "include": ["src"]
}
