{
  "name": "@ton/appkit-react",
  "version": "1.0.0-alpha.0",
  "type": "module",
  "scripts": {
    "build": "pnpm run build:esm && pnpm run copy:css",
    "build:esm": "tsc --project tsconfig.build.json --outDir dist/esm --declarationDir dist/types",
    "dev": "pnpm run copy:css && pnpm run build:esm --watch",
    "copy:css": "copyfiles -u 1 \"src/**/*.css\" dist/esm",
    "clean": "git clean -xdf .turbo dist node_modules",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ton-connect/kit"
  },
  "files": [
    "dist/**",
    "!dist/**/*.tsbuildinfo",
    "src/**/*.ts",
    "src/**/*.tsx",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.stories.tsx"
  ],
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/esm/index.js"
    },
    "./styles.css": "./dist/esm/styles/index.css"
  },
  "typesVersions": {
    "*": {
      "styles.css": [
        "./dist/esm/styles/index.css"
      ]
    }
  },
  "dependencies": {
    "@ton/appkit": "workspace:*",
    "clsx": "2.1.1",
    "radix-ui": "^1.4.3",
    "rosetta": "1.1.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "10.3.5",
    "@storybook/react": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@storybook/test": "^8.6.15",
    "@tanstack/react-query": "catalog:",
    "@tonconnect/ui-react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "copyfiles": "2.4.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "storybook": "10.3.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vite-plugin-node-polyfills": "^0.26.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "@tonconnect/ui": ">=2.4.1",
    "@tonconnect/ui-react": ">=2.4.1",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@tonconnect/ui": {
      "optional": true
    },
    "@tonconnect/ui-react": {
      "optional": true
    }
  },
  "sideEffects": [
    "*.css"
  ]
}
