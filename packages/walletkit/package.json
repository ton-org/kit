{
  "name": "@ton/walletkit",
  "version": "1.0.0-alpha.0",
  "description": "Wallet kit for TON Connect",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ton-connect/kit"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./bridge": {
      "import": {
        "types": "./dist/esm/bridge/JSBridgeInjector.d.ts",
        "default": "./dist/esm/bridge/JSBridgeInjector.js"
      },
      "require": {
        "types": "./dist/cjs/bridge/JSBridgeInjector.d.ts",
        "default": "./dist/cjs/bridge/JSBridgeInjector.js"
      }
    },
    "./swap/omniston": {
      "import": {
        "types": "./dist/esm/defi/swap/omniston/index.d.ts",
        "default": "./dist/esm/defi/swap/omniston/index.js"
      },
      "require": {
        "types": "./dist/cjs/defi/swap/omniston/index.d.ts",
        "default": "./dist/cjs/defi/swap/omniston/index.js"
      }
    },
    "./swap/dedust": {
      "import": {
        "types": "./dist/esm/defi/swap/dedust/index.d.ts",
        "default": "./dist/esm/defi/swap/dedust/index.js"
      },
      "require": {
        "types": "./dist/cjs/defi/swap/dedust/index.d.ts",
        "default": "./dist/cjs/defi/swap/dedust/index.js"
      }
    },
    "./staking/tonstakers": {
      "import": {
        "types": "./dist/esm/defi/staking/tonstakers/index.d.ts",
        "default": "./dist/esm/defi/staking/tonstakers/index.js"
      },
      "require": {
        "types": "./dist/cjs/defi/staking/tonstakers/index.d.ts",
        "default": "./dist/cjs/defi/staking/tonstakers/index.js"
      }
    }
  },
  "typesVersions": {
    "*": {
      "bridge": [
        "./dist/cjs/bridge/JSBridgeInjector.d.ts"
      ],
      "swap/omniston": [
        "./dist/cjs/defi/swap/omniston/index.d.ts"
      ],
      "swap/dedust": [
        "./dist/cjs/defi/swap/dedust/index.d.ts"
      ],
      "staking/tonstakers": [
        "./dist/cjs/defi/staking/tonstakers/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "pnpm build:clean && pnpm build:cjs && pnpm build:esm",
    "build:clean": "rimraf dist",
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "dev": "tsc -p tsconfig.esm.json --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run stryker.config.js",
    "quality": "pnpm test",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --max-warnings 0 --fix",
    "clean": "git clean -xdf dist node_modules .turbo coverage",
    "generate-openapi-spec": "src/api/scripts/generate-openapi-spec.sh",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ton",
    "wallet",
    "connect",
    "tonconnect"
  ],
  "author": "TON Tech",
  "files": [
    "DEVELOPMENT.md",
    "README.md",
    "LICENSE",
    "dist"
  ],
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@scure/bip39": "^2.0.1",
    "@tonconnect/bridge-sdk": "^0.2.8",
    "@tonconnect/protocol": "catalog:",
    "@tonconnect/sdk": "catalog:",
    "lru-cache": "catalog:",
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "@ton/core": "^0.62.0 || ^0.63.0",
    "@ton/crypto": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "@ston-fi/omniston-sdk": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@ston-fi/omniston-sdk": "^0.7.9"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@stryker-mutator/core": "^9.6.1",
    "@ton/core": "catalog:",
    "@ton/crypto": "catalog:",
    "@types/chrome": "^0.1.40",
    "@types/jest": "^30.0.0",
    "@types/webextension-polyfill": "^0.12.4",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/ui": "^4.1.4",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "node-hid": "^3.2.0",
    "rimraf": "^6.1.2",
    "swagger-typescript-api": "13.6.8",
    "ts-jest": "^29.4.9",
    "ts-json-schema-generator": "^2.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.8",
    "vite-bundle-analyzer": "^1.3.7",
    "vitest": "^4.1.4"
  }
}
