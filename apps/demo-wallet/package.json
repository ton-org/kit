{
  "name": "demo-wallet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "e2e:deps": "playwright install --with-deps",
    "e2e": "playwright test --config e2e.config.ts --retries=3",
    "dev": "vite",
    "build": "pnpm build:extension && pnpm build:website",
    "dev:extension": "cross-env VITE_APP_ENV=extension vite build --watch --config vite.extension.config.ts",
    "build:extension": "pnpm build:extension:chrome && pnpm build:extension:firefox",
    "build:extension:chrome": "cross-env VITE_APP_ENV=extension TARGET=chrome vite build --config vite.extension.config.ts",
    "build:extension:firefox": "cross-env VITE_APP_ENV=extension TARGET=firefox vite build --config vite.extension.config.ts",
    "build:website": "tsc -b && vite build",
    "preview": "vite preview",
    "clean": "git clean -xdf .cache .turbo dist dist-extension-chrome dist-extension-firefox node_modules allure-results playwright-report test-results",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@demo/v4ledger-adapter": "workspace:*",
    "@demo/wallet-core": "workspace:*",
    "@fontsource-variable/inter": "^5.2.8",
    "@ledgerhq/hw-transport-webhid": "6.34.0",
    "@ledgerhq/hw-transport-webusb": "6.33.0",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-select": "2.2.6",
    "@scure/bip39": "^2.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@telegram-apps/sdk": "^3.11.8",
    "@ton/core": "catalog:",
    "@ton/crypto": "catalog:",
    "@ton/walletkit": "workspace:*",
    "@truecarry/vite-plugin-web-extension": "^4.5.1",
    "@truecarry/webext-bridge": "^6.0.2",
    "buffer": "catalog:",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "consola": "^3.4.2",
    "framer-motion": "^12.40.0",
    "immer": "^10.2.0",
    "lucide-react": "^0.562.0",
    "next-themes": "^0.4.6",
    "qr-code-styling": "^1.9.2",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "^7.15.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.1.40",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/webextension-polyfill": "^0.12.4",
    "@vitejs/plugin-react": "^6.0.1",
    "allure-js-commons": "^3.7.1",
    "allure-playwright": "^3.7.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-bundle-analyzer": "^1.3.7",
    "webextension-polyfill": "^0.12.0"
  }
}