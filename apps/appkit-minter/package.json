    "@radix-ui/react-tooltip": "1.2.8",
    "@ston-fi/omniston-sdk": "^0.7.9",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "catalog:",
    "@ton/appkit": "workspace:*",
    "@ton/appkit-react": "workspace:*",
    "@ton/core": "catalog:",
    "@ton/crypto": "catalog:",
    "@tonconnect/sdk": "catalog:",
    "@tonconnect/ui-react": "catalog:",
