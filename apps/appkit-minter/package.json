  "scripts": {
    "dev": "vite --port 5174",
    "build": "pnpm typecheck && vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "clean": "git clean -xdf .cache .turbo dist node_modules allure-results playwright-report test-results",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "e2e:deps": "playwright install --with-deps",
    "e2e": "playwright test --config e2e.config.ts --retries=3",
    "e2e:headed": "playwright test --config e2e.config.ts --headed"
  },
